---
interface BlueskyPost {
  uri: string;
  cid: string;
  author: {
    handle: string;
    displayName: string;
    avatar: string;
  };
  record: {
    text: string;
    createdAt: string;
  };
  indexedAt: string;
}

interface Props {
  handle: string;
}

const { handle } = Astro.props;

let post: BlueskyPost | null = null;
let error: string | null = null;

try {
  // Resolve the handle to a DID
  const resolveRes = await fetch(
    `https://public.api.bsky.app/xrpc/com.atproto.identity.resolveHandle?handle=${handle}`
  );
  
  if (!resolveRes.ok) {
    throw new Error(`Failed to resolve handle: ${resolveRes.status}`);
  }
  
  const { did } = await resolveRes.json();
  
  // Fetch the author's feed
  const feedRes = await fetch(
    `https://public.api.bsky.app/xrpc/app.bsky.feed.getAuthorFeed?actor=${did}&limit=1&filter=posts_no_replies`
  );
  
  if (!feedRes.ok) {
    throw new Error(`Failed to fetch feed: ${feedRes.status}`);
  }
  
  const feedData = await feedRes.json();
  
  if (feedData.feed && feedData.feed.length > 0) {
    post = feedData.feed[0].post;
  }
} catch (e) {
  error = e instanceof Error ? e.message : 'Unknown error';
  console.error('Bluesky fetch error:', error);
}

function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

function getPostUrl(uri: string, handle: string): string {
  // URI format: at://did:plc:xxx/app.bsky.feed.post/rkey
  const parts = uri.split('/');
  const rkey = parts[parts.length - 1];
  return `https://bsky.app/profile/${handle}/post/${rkey}`;
}
---

{post && (
  <div class="bluesky-post">
    <a 
      href={getPostUrl(post.uri, handle)} 
      target="_blank" 
      rel="noopener noreferrer"
      class="block hover:bg-primary-800/50 rounded-lg p-4 -m-4 transition-colors"
    >
      <div class="flex items-center gap-2 mb-2 text-sm text-primary-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 600 530" fill="currentColor">
          <path d="m135.72 44.03c66.496 49.921 138.02 151.14 164.28 205.46 26.262-54.316 97.782-155.54 164.28-205.46 47.98-36.021 125.72-63.892 125.72 24.795 0 17.712-10.155 148.79-16.111 170.07-20.703 73.984-96.144 92.854-163.25 81.433 117.3 19.964 147.14 86.092 82.697 152.22-122.39 125.59-175.91-31.511-189.63-71.766-2.514-7.3797-3.6904-10.832-3.7077-7.8964-0.0174-2.9357-1.1937 0.51669-3.7077 7.8964-13.714 40.255-67.233 197.36-189.63 71.766-64.444-66.128-34.605-132.26 82.697-152.22-67.108 11.421-142.55-7.4491-163.25-81.433-5.9562-21.282-16.111-152.36-16.111-170.07 0-88.687 77.742-60.816 125.72-24.795z"/>
        </svg>
        <span>Latest on Bluesky</span>
        <span class="text-primary-500">·</span>
        <span class="text-primary-500">{formatDate(post.record.createdAt)}</span>
      </div>
      <p class="text-primary-100 whitespace-pre-wrap">{post.record.text}</p>
    </a>
  </div>
)}
